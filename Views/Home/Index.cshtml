<section class="mission-section">
    <div class="container">
        <div class="section-header">
            <span class="section-badge">Our Mission</span>
            <h2>Preserving Heritage, Building Futures</h2>
            <p class="section-subtitle">Connecting Senegalese culture with Minnesota community</p>
        </div>
        
        <div class="mission-grid">
            <div class="mission-content">
                <div class="mission-story">
                    <h3>Our Story</h3>
                    <p>Since 2009, the Senegalese Association of Minnesota has served as the cornerstone of our diaspora community in the Twin Cities. We bridge the gap between our cherished homeland traditions and our American journey, ensuring that our rich cultural heritage thrives for generations to come.</p>
                    
                    <div class="impact-highlights">
                        <div class="highlight-item">
                            <div class="highlight-icon">
                                <i class="fas fa-home"></i>
                            </div>
                            <div class="highlight-content">
                                <h4>Community Hub</h4>
                                <p>Central gathering place for cultural events and community support</p>
                            </div>
                        </div>
                        <div class="highlight-item">
                            <div class="highlight-icon">
                                <i class="fas fa-hands-helping"></i>
                            </div>
                            <div class="highlight-content">
                                <h4>Integration Support</h4>
                                <p>Helping families navigate and thrive in American society</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="values-showcase">
                <h3>Guided by Senegalese Values</h3>
                <div class="values-grid">
                    <div class="value-card">
                        <div class="value-icon">🤝</div>
                        <h4>Teranga</h4>
                        <p>Hospitality and warmth that welcomes all</p>
                    </div>
                    <div class="value-card">
                        <div class="value-icon">⭐</div>
                        <h4>Jëf</h4>
                        <p>Honor and dignity in all we do</p>
                    </div>
                    <div class="value-card">
                        <div class="value-icon">👥</div>
                        <h4>Ndey Djirim</h4>
                        <p>Community support and collective care</p>
                    </div>
                    <div class="value-card">
                        <div class="value-icon">📚</div>
                        <h4>Xam-Xam</h4>
                        <p>Knowledge and lifelong learning</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section id="community" class="services-section">
    <div class="container">
        <div class="section-header">
            <span class="section-badge">Community Services</span>
            <h2>How We Serve Our Community</h2>
            <p class="section-subtitle">Comprehensive support for every stage of your journey</p>
        </div>
        
        <div class="services-showcase">
            @if (services != null)
            {
                @foreach (var service in services)
                {
                    <div class="service-card-enhanced">
                        <div class="service-header">
                            @if (!string.IsNullOrEmpty(service.IconClass))
                            {
                                <div class="service-icon-wrapper">
                                    <i class="@service.IconClass"></i>
                                </div>
                            }
                            <h3>@service.Title</h3>
                        </div>
                        <p class="service-description">@service.Description</p>
                        <div class="service-features">
                            @switch (service.Title)
                            {
                                case "Cultural Programs":
                                    <ul>
                                        <li>Wolof language classes</li>
                                        <li>Traditional dance workshops</li>
                                        <li>Music and arts programs</li>
                                    </ul>
                                    break;
                                case "Integration Support":
                                    <ul>
                                        <li>Immigration assistance</li>
                                        <li>Job placement services</li>
                                        <li>Housing resources</li>
                                    </ul>
                                    break;
                                case "Youth Development":
                                    <ul>
                                        <li>Educational tutoring</li>
                                        <li>Leadership programs</li>
                                        <li>College prep support</li>
                                    </ul>
                                    break;
                                case "Social Services":
                                    <ul>
                                        <li>Emergency assistance</li>
                                        <li>Family counseling</li>
                                        <li>Elder care support</li>
                                    </ul>
                                    break;
                            }
                        </div>
                        <a href="#" class="service-link">
                            Learn More <i class="fas fa-arrow-right"></i>
                        </a>
                    </div>
                }
            }
        </div>
    </div>
</section>

