<section id="events" class="events-preview">
    <div class="container">
        <div class="events-header">
            <div class="events-intro">
                <span class="section-badge">Community Calendar</span>
                <h2>Join Our Upcoming Events</h2>
                <p>Experience the vibrant spirit of our community through cultural celebrations, educational programs, and social gatherings.</p>
            </div>
            <a asp-controller="Home" asp-action="Events" class="btn btn-outline">
                View All Events <i class="fas fa-calendar"></i>
            </a>
        </div>
        
        <div class="events-showcase">
            @if (upcomingEvents != null)
            {
                @foreach (var eventItem in upcomingEvents)
                {
                    <div class="event-card-preview">
                        <div class="event-visual">
                            <div class="event-date-badge">
                                <span class="day">@eventItem.Date.Day</span>
                                <span class="month">@eventItem.Date.ToString("MMM")</span>
                            </div>
                            <div class="event-category">
                                <i class="fas fa-users"></i>
                                <span>Community</span>
                            </div>
                        </div>
                        <div class="event-content">
                            <h3>@eventItem.Title</h3>
                            <p>@eventItem.Description</p>
                            <div class="event-meta">
                                <span class="event-time">
                                    <i class="fas fa-clock"></i>
                                    @eventItem.Time
                                </span>
                                @if (!string.IsNullOrEmpty(eventItem.Location))
                                {
                                    <span class="event-location">
                                        <i class="fas fa-map-marker-alt"></i>
                                        @eventItem.Location
                                    </span>
                                }
                            </div>
                        </div>
                        <div class="event-actions">
                            <button class="btn-event-interest">
