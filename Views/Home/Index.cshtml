<section class="president-welcome-section">
    <div class="container">
        <div class="president-welcome">
            <div class="president-content">
                <div class="president-image-container">
                    <div class="president-image">
                        <div class="image-placeholder president-photo">
                            <i class="fas fa-user-tie"></i>
                        </div>
                        <div class="president-badge">
                            <span>President</span>
                        </div>
                    </div>
                    <div class="president-info">
                        <h3>Aida Sarr Lewis</h3>
                        <p class="president-title">President, Senegalese Association of Minnesota</p>
                        <div class="president-credentials">
                            <div class="credential">
                                <i class="fas fa-calendar-alt"></i>
                                <span>Serving since 2020</span>
                            </div>
                            <div class="credential">
                                <i class="fas fa-graduation-cap"></i>
                                <span>Community Leader</span>
                            </div>
                        </div>
                    </div>
                </div>
                
                <div class="welcome-message">
                    <div class="message-header">
                        <span class="welcome-badge">Message from the President</span>
                        <h2>Asalaam Malekum & Welcome to Our Community</h2>
                    </div>
                    
                    <div class="message-content">
                        <blockquote>
                            <p>"As President of the Senegalese Association of Minnesota, I am honored to welcome you to our vibrant community family. Since our founding, we have been dedicated to preserving our beautiful Senegalese culture while building bridges in our new home here in Minnesota."</p>
                            
                            <p>"Our association represents more than just an organization – we are a <em>family</em> bound by our shared heritage, values, and commitment to supporting one another. Whether you are a recent immigrant seeking guidance or a long-time resident looking to stay connected to your roots, you will find a warm welcome here."</p>
                            
                            <p>"We invite you to join us in our mission of <strong>Teranga</strong> (hospitality), <strong>Jëf</strong> (honor), and <strong>Ndey Djirim</strong> (community support). Together, we are building a stronger, more connected Senegalese community in the heart of Minnesota."</p>
                        </blockquote>
                        
                        <div class="message-signature">
                            <div class="signature-line">
                                <span class="signature-name">Aida Sarr Lewis</span>
                                <span class="signature-title">President</span>
                            </div>
                            <div class="signature-quote">
                                <em>"Jëf ak Jëf" - Unity through Community</em>
                            </div>
                        </div>
                    </div>
                    
                    <div class="president-cta">
                        <a asp-controller="Home" asp-action="Contact" class="btn btn-primary">
                            <i class="fas fa-handshake"></i>
                            Connect With Our Leadership
                        </a>
                        <a asp-controller="Home" asp-action="About" class="btn btn-outline">
                            <i class="fas fa-users"></i>
                            Meet Our Team
                        </a>
                    </div>
                </div>
            </div>
            
            <div class="president-highlights">
                <h3>Under President Lewis's Leadership</h3>
                <div class="highlights-grid">
                    <div class="highlight-card">
                        <div class="highlight-icon">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <div class="highlight-content">
                            <span class="highlight-number">300%</span>
                            <span class="highlight-label">Membership Growth</span>
                        </div>
                    </div>
                    <div class="highlight-card">
                        <div class="highlight-icon">
                            <i class="fas fa-graduation-cap"></i>
                        </div>
                        <div class="highlight-content">
                            <span class="highlight-number">50+</span>
                            <span class="highlight-label">Youth Scholarships</span>
                        </div>
                    </div>
                    <div class="highlight-card">
                        <div class="highlight-icon">
                            <i class="fas fa-home"></i>
                        </div>
                        <div class="highlight-content">
                            <span class="highlight-number">200+</span>
                            <span class="highlight-label">Families Supported</span>
                        </div>
                    </div>
                    <div class="highlight-card">
                        <div class="highlight-icon">
                            <i class="fas fa-calendar-check"></i>
                        </div>
                        <div class="highlight-content">
                            <span class="highlight-number">75+</span>
                            <span class="highlight-label">Community Events</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
