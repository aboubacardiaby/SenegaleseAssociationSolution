@model IEnumerable<Event>
@{
    ViewData["Title"] = "Events";
}

<section class="hero-small">
    <div class="container">
        <h1>Community Events</h1>
        <p class="hero-subtitle">Join us for upcoming events and stay connected with our vibrant community.</p>
    </div>
</section>

<section class="events-page">
    <div class="container">
        <div class="events-filter">
            <h2>Upcoming Events</h2>
            <p>Stay informed about all our community gatherings, cultural celebrations, and educational programs.</p>
        </div>

        <div class="events-list">
            @if (Model != null && Model.Any())
            {
                @foreach (var eventItem in Model)
                {
                    <div class="event-card-detailed">
                        <div class="event-date-large">
                            <span class="day">@eventItem.Date.Day</span>
                            <span class="month">@eventItem.Date.ToString("MMM").ToUpper()</span>
                            <span class="year">@eventItem.Date.Year</span>
                        </div>
                        <div class="event-details">
                            <div class="event-header">
                                <h3>@eventItem.Title</h3>
                                <span class="event-category">Community Event</span>
                            </div>
                            <p class="event-description">@eventItem.Description</p>
                            <div class="event-meta">
                                <div class="meta-item">
                                    <i class="fas fa-clock"></i>
                                    <span>@eventItem.Time</span>
                                </div>
                                @if (!string.IsNullOrEmpty(eventItem.Location))
                                {
                                    <div class="meta-item">
                                        <i class="fas fa-map-marker-alt"></i>
                                        <span>@eventItem.Location</span>
                                    </div>
                                }
                            </div>
                            <div class="event-actions">
                                <button class="btn btn-primary btn-sm">Register</button>
                                <button class="btn btn-outline btn-sm">Add to Calendar</button>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="no-events">
                    <i class="fas fa-calendar-times"></i>
                    <h3>No Events Scheduled</h3>
                    <p>Check back soon for upcoming community events and activities.</p>
                </div>
            }
        </div>

        <div class="events-sidebar">
            <div class="sidebar-card">
                <h3>Event Categories</h3>
                <ul class="category-list">
                    <li><a href="#">Community Meetings</a></li>
                    <li><a href="#">Cultural Celebrations</a></li>
                    <li><a href="#">Educational Programs</a></li>
                    <li><a href="#">Youth Activities</a></li>
                    <li><a href="#">Social Services</a></li>
                </ul>
            </div>

            <div class="sidebar-card">
                <h3>Stay Updated</h3>
                <p>Never miss an event! Subscribe to our newsletter for the latest updates on community activities.</p>
                <form class="newsletter-form">
                    <input type="email" placeholder="Your email address" class="form-control">
                    <button type="submit" class="btn btn-primary">Subscribe</button>
                </form>
            </div>

            <div class="sidebar-card">
                <h3>Contact for Events</h3>
                <p>Have questions about our events or want to suggest an activity?</p>
                <a asp-controller="Home" asp-action="Contact" class="btn btn-outline">Contact Us</a>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <style>
        .hero-small {
            background: linear-gradient(135deg, #00A86B 0%, #228B22 50%, #FFD700 100%);
            color: white;
            padding: 120px 0 60px;
            text-align: center;
        }
        
        .hero-small h1 {
            font-size: 3rem;
            margin-bottom: 1rem;
        }
        
        .hero-subtitle {
            font-size: 1.2rem;
            opacity: 0.9;
        }
        
        .events-page {
            padding: 80px 0;
            background: #f8f9fa;
        }
        
        .events-page .container {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 3rem;
        }
        
        .events-filter {
            grid-column: 1 / -1;
            text-align: center;
            margin-bottom: 3rem;
        }
        
        .events-filter h2 {
            color: #333;
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }
        
        .events-list {
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }
        
        .event-card-detailed {
            background: white;
            border-radius: 15px;
            padding: 2rem;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
            display: flex;
            gap: 2rem;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        .event-card-detailed:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(0, 168, 107, 0.15);
        }
        
        .event-date-large {
            background: linear-gradient(135deg, #00A86B 0%, #228B22 100%);
            color: white;
            padding: 1.5rem;
            border-radius: 10px;
            text-align: center;
            min-width: 100px;
            height: fit-content;
        }
        
        .event-date-large .day {
            display: block;
            font-size: 2rem;
            font-weight: 700;
        }
        
        .event-date-large .month {
            display: block;
            font-size: 1rem;
            font-weight: 500;
            opacity: 0.9;
        }
        
        .event-date-large .year {
            display: block;
            font-size: 0.9rem;
            opacity: 0.8;
        }
        
        .event-details {
            flex: 1;
        }
        
        .event-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 1rem;
        }
        
        .event-header h3 {
            color: #333;
            font-size: 1.5rem;
            margin: 0;
        }
        
        .event-category {
            background: #FFD700;
            color: #333;
            padding: 0.3rem 0.8rem;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 600;
        }
        
        .event-description {
            color: #666;
            line-height: 1.6;
            margin-bottom: 1.5rem;
        }
        
        .event-meta {
            display: flex;
            gap: 2rem;
            margin-bottom: 1.5rem;
        }
        
        .meta-item {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: #00A86B;
        }
        
        .meta-item i {
            font-size: 0.9rem;
        }
        
        .event-actions {
            display: flex;
            gap: 1rem;
        }
        
        .btn-sm {
            padding: 0.5rem 1rem;
            font-size: 0.9rem;
        }
        
        .btn-outline {
            background: transparent;
            border: 2px solid #00A86B;
            color: #00A86B;
        }
        
        .btn-outline:hover {
            background: #00A86B;
            color: white;
        }
        
        .events-sidebar {
            display: flex;
            flex-direction: column;
            gap: 2rem;
        }
        
        .sidebar-card {
            background: white;
            padding: 2rem;
            border-radius: 15px;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
        }
        
        .sidebar-card h3 {
            color: #00A86B;
            margin-bottom: 1rem;
        }
        
        .category-list {
            list-style: none;
            padding: 0;
        }
        
        .category-list li {
            margin-bottom: 0.5rem;
        }
        
        .category-list a {
            color: #666;
            text-decoration: none;
            transition: color 0.3s ease;
        }
        
        .category-list a:hover {
            color: #00A86B;
        }
        
        .newsletter-form {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }
        
        .newsletter-form input {
            padding: 0.8rem;
            border: 2px solid #e9ecef;
            border-radius: 8px;
            font-family: inherit;
        }
        
        .newsletter-form input:focus {
            outline: none;
            border-color: #00A86B;
        }
        
        .no-events {
            text-align: center;
            padding: 4rem 2rem;
            color: #666;
        }
        
        .no-events i {
            font-size: 4rem;
            margin-bottom: 1rem;
            opacity: 0.5;
        }
        
        @@media (max-width: 768px) {
            .events-page .container {
                grid-template-columns: 1fr;
            }
            
            .event-card-detailed {
                flex-direction: column;
                text-align: center;
            }
            
            .event-date-large {
                align-self: center;
            }
            
            .event-header {
                flex-direction: column;
                gap: 0.5rem;
                text-align: center;
            }
            
            .event-meta {
                justify-content: center;
                flex-wrap: wrap;
            }
            
            .event-actions {
                justify-content: center;
            }
        }
    </style>
}