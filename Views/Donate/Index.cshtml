@{
    ViewData["Title"] = "Support Our Community";
}

@Html.AntiForgeryToken()

<section class="hero-small">
    <div class="container">
        <h1>Support Our Community</h1>
        <p class="hero-subtitle">Your generous donations help us strengthen our community and preserve our Senegalese heritage in Minnesota.</p>
    </div>
</section>

<section class="donate-page">
    <div class="container">
        <!-- Donation Frequency Selection -->
        <div class="frequency-selection">
            <h2>Choose Your Donation Frequency</h2>
            <div class="frequency-buttons">
                <button class="frequency-btn active" data-frequency="one-time">
                    <i class="fas fa-hand-holding-heart"></i>
                    <span>One-Time</span>
                </button>
                <button class="frequency-btn" data-frequency="monthly">
                    <i class="fas fa-calendar-alt"></i>
                    <span>Monthly</span>
                </button>
                <button class="frequency-btn" data-frequency="annual">
                    <i class="fas fa-calendar-check"></i>
                    <span>Annual</span>
                </button>
            </div>
        </div>

        <!-- Donation Amount Options -->
        <div class="amount-selection">
            <h3>Select Donation Amount</h3>
            <div class="amount-buttons">
                <button class="amount-btn" data-amount="25">$25</button>
                <button class="amount-btn" data-amount="50">$50</button>
                <button class="amount-btn active" data-amount="100">$100</button>
                <button class="amount-btn" data-amount="250">$250</button>
                <button class="amount-btn" data-amount="500">$500</button>
                <button class="amount-btn custom">
                    <input type="number" id="customAmount" placeholder="Custom" min="1" step="1">
                </button>
            </div>
        </div>

        <!-- Donor Information Form -->
        <div class="donor-information">
            <h3>Your Information</h3>
            <form id="donorForm">
                <div class="form-row">
                    <div class="form-group">
                        <label for="donorName">Full Name *</label>
                        <input type="text" id="donorName" name="donorName" class="form-control" required>
                    </div>
                    <div class="form-group">
                        <label for="donorEmail">Email Address *</label>
                        <input type="email" id="donorEmail" name="donorEmail" class="form-control" required>
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label for="donorPhone">Phone Number</label>
                        <input type="tel" id="donorPhone" name="donorPhone" class="form-control">
                    </div>
                    <div class="form-group checkbox-group">
                        <label>
                            <input type="checkbox" id="isAnonymous" name="isAnonymous">
                            <span>Make this donation anonymous</span>
                        </label>
                    </div>
                </div>
                <div class="form-group">
                    <label for="donorMessage">Message (Optional)</label>
                    <textarea id="donorMessage" name="donorMessage" class="form-control" rows="3" placeholder="Leave a message with your donation..."></textarea>
                </div>
            </form>
        </div>

        <!-- Payment Methods -->
        <div class="payment-methods">
            <h3>Choose Your Payment Method</h3>
            <div class="payment-grid">
                <div class="payment-card">
                    <div class="payment-icon">
                        <i class="fab fa-paypal"></i>
                    </div>
                    <h4>PayPal</h4>
                    <p>Secure payment through PayPal</p>
                    <button class="btn btn-primary payment-btn" data-method="paypal">
                        Donate with PayPal
                    </button>
                </div>

                <div class="payment-card">
                    <div class="payment-icon zelle">
                        <i class="fas fa-mobile-alt"></i>
                    </div>
                    <h4>Zelle</h4>
                    <p>Send directly via Zelle</p>
                    <button class="btn btn-primary payment-btn" data-method="zelle">
                        Pay with Zelle
                    </button>
                    <div class="payment-info" style="display: none;">
                        <p><strong>Zelle Email:</strong><br>donations@@senegalese-mn.org</p>
                    </div>
                </div>

                <div class="payment-card">
                    <div class="payment-icon venmo">
                        <i class="fab fa-cc-visa"></i>
                    </div>
                    <h4>Venmo</h4>
                    <p>Quick payment via Venmo</p>
                    <button class="btn btn-primary payment-btn" data-method="venmo">
                        Pay with Venmo
                    </button>
                    <div class="payment-info" style="display: none;">
                        <p><strong>Venmo Handle:</strong><br>@@SenegaleseMN</p>
                    </div>
                </div>

                <div class="payment-card">
                    <div class="payment-icon ach">
                        <i class="fas fa-university"></i>
                    </div>
                    <h4>ACH Transfer</h4>
                    <p>Direct bank transfer</p>
                    <button class="btn btn-primary payment-btn" data-method="ach">
                        ACH Transfer
                    </button>
                    <div class="payment-info" style="display: none;">
                        <p><strong>Bank:</strong> First National Bank<br>
                        <strong>Routing:</strong> 123456789<br>
                        <strong>Account:</strong> 987654321<br>
                        <strong>Account Name:</strong> Senegalese Association of MN</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Impact Information -->
        <div class="impact-section">
            <h2>Your Impact</h2>
            <div class="impact-grid">
                <div class="impact-card">
                    <i class="fas fa-users"></i>
                    <h4>Community Programs</h4>
                    <p>Support cultural events, language classes, and community gatherings that keep our heritage alive.</p>
                </div>
                <div class="impact-card">
                    <i class="fas fa-hands-helping"></i>
                    <h4>Member Support</h4>
                    <p>Help new immigrants settle, provide resources, and offer assistance to community members in need.</p>
                </div>
                <div class="impact-card">
                    <i class="fas fa-graduation-cap"></i>
                    <h4>Educational Initiatives</h4>
                    <p>Fund scholarships, tutoring programs, and educational workshops for our youth.</p>
                </div>
                <div class="impact-card">
                    <i class="fas fa-heart"></i>
                    <h4>Emergency Relief</h4>
                    <p>Provide immediate assistance to community members and families facing hardship.</p>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <style>
        .hero-small {
            background: linear-gradient(135deg, #00A86B 0%, #228B22 50%, #FFD700 100%);
            color: white;
            padding: 120px 0 60px;
            text-align: center;
        }

        .hero-small h1 {
            font-size: 3rem;
            margin-bottom: 1rem;
        }

        .hero-subtitle {
            font-size: 1.2rem;
            opacity: 0.9;
            max-width: 700px;
            margin: 0 auto;
        }

        .donate-page {
            padding: 80px 0;
            background: #f8f9fa;
        }

        .frequency-selection,
        .amount-selection,
        .donor-information,
        .payment-methods {
            background: white;
            padding: 3rem;
            border-radius: 15px;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
            margin-bottom: 3rem;
        }

        .frequency-selection h2,
        .payment-methods h3,
        .donor-information h3,
        .amount-selection h3 {
            color: #333;
            margin-bottom: 2rem;
            text-align: center;
            font-size: 2rem;
        }

        .donor-information .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1.5rem;
            margin-bottom: 1.5rem;
        }

        .donor-information .form-group {
            display: flex;
            flex-direction: column;
        }

        .donor-information .form-group label {
            color: #333;
            font-weight: 600;
            margin-bottom: 0.5rem;
            font-size: 1rem;
        }

        .donor-information .form-control {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid #e9ecef;
            border-radius: 8px;
            font-family: inherit;
            font-size: 1rem;
            transition: border-color 0.3s ease;
        }

        .donor-information .form-control:focus {
            outline: none;
            border-color: #00A86B;
            box-shadow: 0 0 0 3px rgba(0, 168, 107, 0.1);
        }

        .donor-information textarea.form-control {
            resize: vertical;
            min-height: 80px;
        }

        .donor-information .checkbox-group {
            display: flex;
            align-items: center;
            justify-content: flex-start;
        }

        .donor-information .checkbox-group label {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            cursor: pointer;
            margin: 0;
        }

        .donor-information .checkbox-group input[type="checkbox"] {
            width: 20px;
            height: 20px;
            cursor: pointer;
        }

        .frequency-buttons {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 1.5rem;
            max-width: 800px;
            margin: 0 auto;
        }

        .frequency-btn {
            background: white;
            border: 2px solid #e9ecef;
            padding: 2rem 1.5rem;
            border-radius: 12px;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 0.75rem;
            font-size: 1.1rem;
            font-weight: 600;
            color: #666;
        }

        .frequency-btn i {
            font-size: 2.5rem;
            color: #00A86B;
        }

        .frequency-btn:hover,
        .frequency-btn.active {
            border-color: #00A86B;
            background: linear-gradient(135deg, rgba(0, 168, 107, 0.05) 0%, rgba(34, 139, 34, 0.05) 100%);
            color: #00A86B;
            transform: translateY(-3px);
            box-shadow: 0 5px 15px rgba(0, 168, 107, 0.2);
        }

        .amount-buttons {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
            gap: 1rem;
            max-width: 800px;
            margin: 0 auto;
        }

        .amount-btn {
            background: white;
            border: 2px solid #e9ecef;
            padding: 1.5rem 1rem;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 1.3rem;
            font-weight: 700;
            color: #333;
        }

        .amount-btn:hover,
        .amount-btn.active {
            border-color: #00A86B;
            background: linear-gradient(135deg, #00A86B 0%, #228B22 100%);
            color: white;
            transform: scale(1.05);
        }

        .amount-btn.custom {
            padding: 0;
        }

        .amount-btn.custom input {
            width: 100%;
            height: 100%;
            border: none;
            background: transparent;
            padding: 1.5rem 1rem;
            font-size: 1.1rem;
            font-weight: 600;
            text-align: center;
            border-radius: 8px;
        }

        .amount-btn.custom input:focus {
            outline: none;
        }

        .payment-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
            margin-top: 2rem;
        }

        .payment-card {
            background: white;
            border: 2px solid #e9ecef;
            padding: 2rem;
            border-radius: 15px;
            text-align: center;
            transition: all 0.3s ease;
        }

        .payment-card:hover {
            border-color: #00A86B;
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0, 168, 107, 0.15);
        }

        .payment-icon {
            background: linear-gradient(135deg, #00A86B 0%, #228B22 100%);
            color: white;
            width: 80px;
            height: 80px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 2rem;
        }

        .payment-icon.zelle {
            background: linear-gradient(135deg, #6D1ED4 0%, #4B0082 100%);
        }

        .payment-icon.venmo {
            background: linear-gradient(135deg, #3D95CE 0%, #008CFF 100%);
        }

        .payment-icon.ach {
            background: linear-gradient(135deg, #2C3E50 0%, #34495E 100%);
        }

        .payment-card h4 {
            color: #333;
            margin-bottom: 0.5rem;
            font-size: 1.5rem;
        }

        .payment-card p {
            color: #666;
            margin-bottom: 1.5rem;
        }

        .payment-btn {
            width: 100%;
            padding: 12px 20px;
            background: linear-gradient(135deg, #00A86B 0%, #228B22 100%);
            color: white;
            border: none;
            border-radius: 8px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .payment-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(0, 168, 107, 0.3);
        }

        .payment-info {
            margin-top: 1.5rem;
            padding: 1rem;
            background: #f8f9fa;
            border-radius: 8px;
            text-align: left;
            font-size: 0.9rem;
        }

        .payment-info p {
            margin: 0.5rem 0;
            color: #333;
        }

        .payment-info strong {
            color: #00A86B;
        }

        .impact-section {
            margin-top: 4rem;
        }

        .impact-section h2 {
            text-align: center;
            color: #333;
            font-size: 2.5rem;
            margin-bottom: 3rem;
        }

        .impact-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 2rem;
        }

        .impact-card {
            background: white;
            padding: 2.5rem;
            border-radius: 15px;
            box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
            text-align: center;
            transition: transform 0.3s ease;
        }

        .impact-card:hover {
            transform: translateY(-5px);
        }

        .impact-card i {
            font-size: 3rem;
            color: #00A86B;
            margin-bottom: 1.5rem;
        }

        .impact-card h4 {
            color: #333;
            margin-bottom: 1rem;
            font-size: 1.3rem;
        }

        .impact-card p {
            color: #666;
            line-height: 1.6;
        }

        @@media (max-width: 768px) {
            .hero-small h1 {
                font-size: 2.5rem;
            }

            .frequency-buttons {
                grid-template-columns: 1fr;
            }

            .amount-buttons {
                grid-template-columns: repeat(2, 1fr);
            }

            .payment-grid,
            .impact-grid {
                grid-template-columns: 1fr;
            }

            .frequency-selection,
            .amount-selection,
            .donor-information,
            .payment-methods {
                padding: 2rem 1.5rem;
            }

            .donor-information .form-row {
                grid-template-columns: 1fr;
            }
        }
    </style>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            let selectedFrequency = 'one-time';
            let selectedAmount = 100;

            // Frequency selection
            document.querySelectorAll('.frequency-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('.frequency-btn').forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    selectedFrequency = this.dataset.frequency;
                    updateDonationSummary();
                });
            });

            // Amount selection
            document.querySelectorAll('.amount-btn:not(.custom)').forEach(btn => {
                btn.addEventListener('click', function() {
                    document.querySelectorAll('.amount-btn').forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    selectedAmount = this.dataset.amount;
                    document.getElementById('customAmount').value = '';
                    updateDonationSummary();
                });
            });

            // Custom amount
            document.getElementById('customAmount').addEventListener('input', function() {
                if (this.value) {
                    document.querySelectorAll('.amount-btn').forEach(b => b.classList.remove('active'));
                    this.parentElement.classList.add('active');
                    selectedAmount = this.value;
                    updateDonationSummary();
                }
            });

            // Payment method buttons
            document.querySelectorAll('.payment-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    const method = this.dataset.method;
                    const card = this.closest('.payment-card');
                    const info = card.querySelector('.payment-info');

                    // Toggle payment info visibility
                    if (info) {
                        const isHidden = info.style.display === 'none';
                        document.querySelectorAll('.payment-info').forEach(i => i.style.display = 'none');
                        if (isHidden) {
                            info.style.display = 'block';
                        }
                    }

                    // Handle payment processing
                    processDonation(method, selectedAmount, selectedFrequency);
                });
            });

            function updateDonationSummary() {
                console.log(`Donation: $${selectedAmount} - ${selectedFrequency}`);
            }

            function processDonation(method, amount, frequency) {
                // Validate donor information
                const donorName = document.getElementById('donorName').value.trim();
                const donorEmail = document.getElementById('donorEmail').value.trim();
                const donorPhone = document.getElementById('donorPhone').value.trim();
                const donorMessage = document.getElementById('donorMessage').value.trim();
                const isAnonymous = document.getElementById('isAnonymous').checked;

                if (!donorName || !donorEmail) {
                    alert('Please fill in your name and email address before proceeding.');
                    return;
                }

                if (!amount || amount <= 0) {
                    alert('Please select or enter a valid donation amount.');
                    return;
                }

                // Prepare donation data
                const donationData = {
                    Amount: parseFloat(amount),
                    Frequency: frequency.charAt(0).toUpperCase() + frequency.slice(1).replace('-', ''),
                    PaymentMethod: method.charAt(0).toUpperCase() + method.slice(1),
                    DonorName: donorName,
                    DonorEmail: donorEmail,
                    DonorPhone: donorPhone,
                    Message: donorMessage,
                    IsAnonymous: isAnonymous
                };

                // Get anti-forgery token
                const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

                // Submit to backend
                fetch('@Url.Action("ProcessDonation", "Donate")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify(donationData)
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        // Check if payment requires redirect (PayPal or Stripe)
                        if (data.redirectUrl) {
                            // Redirect to payment provider (PayPal or Stripe)
                            alert(`Redirecting to ${data.paymentProvider} to complete your donation...\n\nTransaction ID: ${data.transactionId}`);
                            window.location.href = data.redirectUrl;
                        } else {
                            // For other payment methods (Zelle, Venmo), show payment information
                            alert(`Thank you for your donation!\n\nTransaction ID: ${data.transactionId}\n\n${data.message}\n\nPlease use the payment information shown below to complete your ${frequency} donation of $${amount} via ${method}.`);
                        }
                    } else {
                        alert('Error: ' + data.message);
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('An error occurred while processing your donation. Please try again.');
                });
            }
        });
    </script>
}
