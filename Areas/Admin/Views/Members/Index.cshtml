@model IEnumerable<SenegaleseAssociation.Areas.Admin.Models.MemberListViewModel>
@{
    ViewData["Title"] = "Members Management";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">
        <i class="fas fa-users text-primary"></i> Members Management
    </h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <div class="btn-group me-2">
            <button type="button" class="btn btn-outline-secondary" onclick="filterMembers('all')">All</button>
            <button type="button" class="btn btn-outline-warning" onclick="filterMembers('pending')">Pending</button>
            <button type="button" class="btn btn-outline-success" onclick="filterMembers('active')">Active</button>
            <button type="button" class="btn btn-outline-danger" onclick="filterMembers('suspended')">Suspended</button>
        </div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Summary Cards -->
<div class="row mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card border-left-primary shadow h-100">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Total Members</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.Count()</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-users fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-left-warning shadow h-100">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Pending Approval</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.Count(m => m.MembershipStatus == "Pending")</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-clock fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-left-success shadow h-100">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Active Members</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.Count(m => m.MembershipStatus == "Active")</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-user-check fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6">
        <div class="card border-left-danger shadow h-100">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Suspended</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.Count(m => m.MembershipStatus == "Suspended")</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-user-slash fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

<div class="card shadow">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">All Members</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" id="dataTable">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Location</th>
                        <th>Status</th>
                        <th>Registration Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var member in Model)
                    {
                        <tr class="member-row" data-status="@member.MembershipStatus.ToLower()">
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="avatar-sm bg-primary text-white rounded-circle me-2 d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                        @member.FullName.First()
                                    </div>
                                    <strong>@member.FullName</strong>
                                </div>
                            </td>
                            <td>@member.Email</td>
                            <td>@member.PhoneNumber</td>
                            <td>
                                @if (!string.IsNullOrEmpty(member.City) || !string.IsNullOrEmpty(member.Country))
                                {
                                    if (!string.IsNullOrEmpty(member.City))
                                    {
                                        @member.City
                                        if (!string.IsNullOrEmpty(member.Country))
                                        {
                                            <text>, </text>
                                        }
                                    }
                                    if (!string.IsNullOrEmpty(member.Country))
                                    {
                                        @member.Country
                                    }
                                }
                            </td>
                            <td>
                                @switch (member.MembershipStatus)
                                {
                                    case "Pending":
                                        <span class="badge bg-warning">Pending</span>
                                        break;
                                    case "Active":
                                        <span class="badge bg-success">Active</span>
                                        break;
                                    case "Suspended":
                                        <span class="badge bg-danger">Suspended</span>
                                        break;
                                    case "Rejected":
                                        <span class="badge bg-secondary">Rejected</span>
                                        break;
                                    default:
                                        <span class="badge bg-light text-dark">@member.MembershipStatus</span>
                                        break;
                                }
                            </td>
                            <td>@member.RegistrationDate.ToString("MM/dd/yyyy")</td>
                            <td>
                                <div class="btn-group" role="group">
                                    <a asp-action="Details" asp-route-id="@member.Id" class="btn btn-sm btn-info" title="View Details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@member.Id" class="btn btn-sm btn-primary" title="Edit Member">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button type="button" class="btn btn-sm btn-secondary" onclick="showActionModal(@member.Id, '@member.FullName', '@member.MembershipStatus')" title="Actions">
                                        <i class="fas fa-cog"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Action Modal -->
<div class="modal fade" id="actionModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Member Actions</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <h6 id="memberName" class="mb-3"></h6>
                <div id="actionButtons"></div>
                <div id="reasonSection" class="mt-3" style="display: none;">
                    <label for="actionReason" class="form-label">Reason (optional):</label>
                    <textarea id="actionReason" class="form-control" rows="3"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" id="confirmActionBtn" class="btn btn-primary" onclick="executeAction()">Confirm</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentMemberId = 0;
        let currentAction = '';

        $(document).ready(function() {
            $('#dataTable').DataTable({
                "order": [[ 5, "desc" ]],
                "pageLength": 25,
                "columnDefs": [
                    {
                        "targets": -1, // Last column (Actions)
                        "orderable": false,
                        "searchable": false
                    }
                ]
            });
        });

        function filterMembers(status) {
            const rows = document.querySelectorAll('.member-row');
            rows.forEach(row => {
                if (status === 'all' || row.dataset.status === status) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }

        function showActionModal(memberId, memberName, status) {
            currentMemberId = memberId;
            document.getElementById('memberName').textContent = `Actions for: ${memberName}`;
            
            let buttons = '';
            
            if (status === 'Pending') {
                buttons += '<button type="button" class="btn btn-success me-2" onclick="setAction(\'approve\')"><i class="fas fa-check"></i> Approve</button>';
                buttons += '<button type="button" class="btn btn-danger" onclick="setAction(\'reject\')"><i class="fas fa-times"></i> Reject</button>';
            } else if (status === 'Active') {
                buttons += '<button type="button" class="btn btn-warning" onclick="setAction(\'suspend\')"><i class="fas fa-pause"></i> Suspend</button>';
            } else if (status === 'Suspended' || status === 'Rejected') {
                buttons += '<button type="button" class="btn btn-success" onclick="setAction(\'reactivate\')"><i class="fas fa-play"></i> Reactivate</button>';
            }
            
            buttons += '<button type="button" class="btn btn-danger ms-2" onclick="setAction(\'delete\')"><i class="fas fa-trash"></i> Delete</button>';
            
            document.getElementById('actionButtons').innerHTML = buttons;
            
            const modal = new bootstrap.Modal(document.getElementById('actionModal'));
            modal.show();
        }

        function setAction(action) {
            currentAction = action;
            const reasonSection = document.getElementById('reasonSection');
            const confirmBtn = document.getElementById('confirmActionBtn');
            
            if (action === 'reject' || action === 'suspend') {
                reasonSection.style.display = 'block';
            } else {
                reasonSection.style.display = 'none';
            }
            
            // Update button color based on action
            confirmBtn.className = 'btn ';
            switch(action) {
                case 'approve':
                case 'reactivate':
                    confirmBtn.className += 'btn-success';
                    break;
                case 'suspend':
                    confirmBtn.className += 'btn-warning';
                    break;
                case 'reject':
                case 'delete':
                    confirmBtn.className += 'btn-danger';
                    break;
                default:
                    confirmBtn.className += 'btn-primary';
            }
        }

        function executeAction() {
            if (!currentAction) return;
            
            const reason = document.getElementById('actionReason').value;
            const form = document.createElement('form');
            form.method = 'POST';
            form.action = '/Admin/Members/' + currentAction;
            
            // Add anti-forgery token
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) {
                const tokenInput = document.createElement('input');
                tokenInput.type = 'hidden';
                tokenInput.name = '__RequestVerificationToken';
                tokenInput.value = token.value;
                form.appendChild(tokenInput);
            }
            
            // Add member ID
            const idInput = document.createElement('input');
            idInput.type = 'hidden';
            idInput.name = 'id';
            idInput.value = currentMemberId;
            form.appendChild(idInput);
            
            // Add reason if provided
            if (reason) {
                const reasonInput = document.createElement('input');
                reasonInput.type = 'hidden';
                reasonInput.name = 'reason';
                reasonInput.value = reason;
                form.appendChild(reasonInput);
            }
            
            document.body.appendChild(form);
            form.submit();
        }
    </script>
    
    <style>
        /* Ensure buttons are clickable and visible */
        .btn-group .btn {
            position: relative;
            z-index: 1;
            pointer-events: auto;
        }
        
        /* Fix potential DataTables CSS conflicts */
        table.dataTable .btn-group {
            display: inline-flex;
        }
        
        .btn-sm {
            padding: 4px 8px;
            font-size: 12px;
            margin-right: 2px;
        }
        
        /* Ensure links in tables work */
        table a {
            text-decoration: none;
        }
        
        table a:hover {
            text-decoration: none;
        }
    </style>
}