<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SAM Admin</title>
    <link rel="stylesheet" href="@Url.Content("~/lib/bootstrap/dist/css/bootstrap.min.css")" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.3/css/dataTables.bootstrap5.min.css" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Nunito:wght%40400;600;700;800&display=swap" />
    <link rel="stylesheet" href="@Url.Content("~/css/admin.css")" />
    @await RenderSectionAsync("Styles", required: false)

    <script type="text/javascript">
    // =============================================
    // Admin Panel - Core JS
    // =============================================
    class AdminPanel {
        constructor() {
            this.charts = new Map();
            this.observers = new Map();
            this.controllers = new Map();
            if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', () => this.init());
            } else {
                this.init();
            }
        }

        async init() {
            try {
                await this.initializeComponents();
                this.bindEvents();
                this.loadAnimations();
                this.createToastContainer();
            } catch (error) {
                console.error('Admin panel init error:', error);
            }
        }

        async initializeComponents() {
            if (typeof bootstrap !== 'undefined') {
                document.querySelectorAll('[data-bs-toggle="tooltip"]')
                    .forEach(el => new bootstrap.Tooltip(el));
                document.querySelectorAll('[data-bs-toggle="popover"]')
                    .forEach(el => new bootstrap.Popover(el));
            }
            if (typeof DataTable !== 'undefined') {
                document.querySelectorAll('.data-table').forEach(table => {
                    new DataTable(table, {
                        responsive: true,
                        pageLength: 25,
                        language: {
                            search: "Search:",
                            lengthMenu: "Show _MENU_ entries",
                            info: "Showing _START_ to _END_ of _TOTAL_ entries",
                            infoEmpty: "No entries to show",
                            infoFiltered: "(filtered from _MAX_ total)"
                        }
                    });
                });
            }
            await this.initializeCharts();
        }

        bindEvents() {
            this.handleAlerts();
            this.handleDeleteActions();
            this.handleTextareas();
            this.handleFormValidation();
            this.handleSearch();
            this.handleStatusUpdates();
            this.handleLoadingStates();
            this.handleFileUploads();
            this.handleGlobalErrors();
            this.handleWindowResize();
        }

        handleAlerts() {
            document.querySelectorAll('.alert:not(.alert-permanent)').forEach(alert => {
                setTimeout(() => {
                    alert.style.transition = 'opacity 0.5s ease-out';
                    alert.style.opacity = '0';
                    setTimeout(() => alert.remove(), 500);
                }, 5000);
            });
            document.addEventListener('click', (e) => {
                if (e.target.matches('.alert .btn-close')) {
                    const alert = e.target.closest('.alert');
                    alert.style.transition = 'opacity 0.3s ease-out';
                    alert.style.opacity = '0';
                    setTimeout(() => alert.remove(), 300);
                }
            });
        }

        handleDeleteActions() {
            document.addEventListener('click', async (e) => {
                const button = e.target.matches('.btn-delete') ? e.target : e.target.closest('.btn-delete');
                if (!button) return;
                e.preventDefault();
                const itemName = button.dataset.itemName || 'this item';
                const confirmed = await this.showDeleteConfirmation(itemName);
                if (confirmed) {
                    const form = button.closest('form');
                    if (form) form.submit();
                    else window.location.href = button.getAttribute('href');
                }
            });
        }

        async showDeleteConfirmation(itemName) {
            return new Promise((resolve) => {
                const modal = this.createModal({
                    id: 'deleteConfirmModal',
                    title: '<i class="fas fa-exclamation-triangle me-2"></i>Confirm Deletion',
                    body: `<p>Are you sure you want to delete <strong>${this.escapeHtml(itemName)}</strong>?</p>
                           <p class="text-muted small mb-0">This action cannot be undone.</p>`,
                    headerClass: 'bg-danger text-white',
                    buttons: [
                        { text: 'Cancel', class: 'btn-secondary', action: () => resolve(false) },
                        { text: '<i class="fas fa-trash me-1"></i>Delete', class: 'btn-danger', action: () => resolve(true) }
                    ]
                });
                document.body.appendChild(modal);
                const modalInstance = new bootstrap.Modal(modal);
                modalInstance.show();
                modal.addEventListener('hidden.bs.modal', () => modal.remove());
            });
        }

        handleTextareas() {
            document.querySelectorAll('textarea.auto-resize').forEach(textarea => {
                this.resizeTextarea(textarea);
                textarea.addEventListener('input', () => this.resizeTextarea(textarea));
            });
        }

        resizeTextarea(textarea) {
            textarea.style.height = 'auto';
            textarea.style.height = `${textarea.scrollHeight}px`;
        }

        handleFormValidation() {
            document.querySelectorAll('.form-control').forEach(control => {
                control.addEventListener('blur', () => this.validateField(control));
                control.addEventListener('input', () => {
                    control.classList.remove('is-valid', 'is-invalid');
                    const err = control.parentNode.querySelector('.invalid-feedback');
                    if (err) err.remove();
                });
            });
        }

        validateField(field) {
            const value = field.value.trim();
            field.classList.remove('is-valid', 'is-invalid');
            if (field.hasAttribute('required') && value === '') {
                field.classList.add('is-invalid');
                this.showFieldError(field, 'This field is required');
            } else if (field.type === 'email' && value !== '' && !this.validateEmail(value)) {
                field.classList.add('is-invalid');
                this.showFieldError(field, 'Please enter a valid email address');
            } else if (value !== '') {
                field.classList.add('is-valid');
                const err = field.parentNode.querySelector('.invalid-feedback');
                if (err) err.remove();
            }
        }

        handleSearch() {
            document.querySelectorAll('.search-input').forEach(input => {
                let timeoutId;
                input.addEventListener('input', () => {
                    clearTimeout(timeoutId);
                    timeoutId = setTimeout(() => {
                        const term = input.value.toLowerCase();
                        const target = document.querySelector(input.dataset.searchTarget);
                        if (target) {
                            target.querySelectorAll('.searchable-item').forEach(item => {
                                item.style.display = item.textContent.toLowerCase().includes(term) ? '' : 'none';
                            });
                        }
                    }, 300);
                });
            });
        }

        handleStatusUpdates() {
            document.addEventListener('click', async (e) => {
                const button = e.target.matches('.btn-status-update') ? e.target : e.target.closest('.btn-status-update');
                if (!button) return;
                e.preventDefault();
                const original = button.innerHTML;
                try {
                    button.innerHTML = '<span class="spinner"></span> Updating...';
                    button.disabled = true;
                    await this.delay(1000);
                    button.innerHTML = '<i class="fas fa-check me-1"></i>Updated';
                    button.classList.replace('btn-warning', 'btn-success');
                    await this.delay(2000);
                    button.innerHTML = original;
                    button.classList.replace('btn-success', 'btn-warning');
                    button.disabled = false;
                } catch {
                    button.innerHTML = original;
                    button.disabled = false;
                }
            });
        }

        handleLoadingStates() {
            document.addEventListener('submit', (e) => {
                if (e.target.matches('form')) {
                    const btn = e.target.querySelector('button[type="submit"]');
                    if (btn) {
                        btn.innerHTML = '<span class="spinner"></span> Processing...';
                        btn.disabled = true;
                    }
                }
            });
        }

        handleFileUploads() {
            document.querySelectorAll('.file-upload-area').forEach(area => {
                area.addEventListener('dragover', e => { e.preventDefault(); area.classList.add('drag-over'); });
                area.addEventListener('dragleave', e => { e.preventDefault(); area.classList.remove('drag-over'); });
                area.addEventListener('drop', e => {
                    e.preventDefault();
                    area.classList.remove('drag-over');
                    this.handleFiles(Array.from(e.dataTransfer.files), area);
                });
                const input = area.querySelector('.file-input');
                if (input) input.addEventListener('change', e => this.handleFiles(Array.from(e.target.files), area));
            });
        }

        handleFiles(files, container) {
            files.forEach(file => {
                if (this.validateFile(file)) this.displayFilePreview(file, container);
                else this.showToast('Invalid file type or size', 'error');
            });
        }

        validateFile(file) {
            return ['image/jpeg','image/png','image/gif','application/pdf'].includes(file.type)
                && file.size <= 5 * 1024 * 1024;
        }

        async displayFilePreview(file, container) {
            try {
                const dataUrl = await this.readFileAsDataURL(file);
                const preview = document.createElement('div');
                preview.className = 'file-preview';
                preview.innerHTML = `
                    <img src="${dataUrl}" alt="${this.escapeHtml(file.name)}" class="preview-image">
                    <div class="file-info">
                        <span class="file-name">${this.escapeHtml(file.name)}</span>
                        <span class="file-size">${this.formatFileSize(file.size)}</span>
                    </div>
                    <button type="button" class="btn btn-sm btn-danger remove-file"><i class="fas fa-times"></i></button>
                `;
                preview.querySelector('.remove-file').addEventListener('click', () => preview.remove());
                const previews = container.querySelector('.file-previews');
                if (previews) previews.appendChild(preview);
            } catch (error) {
                this.showToast('Error creating file preview', 'error');
            }
        }

        async initializeCharts() {
            if (typeof Chart === 'undefined') return;

            const financialCtx = document.getElementById('financialChart');
            if (financialCtx) {
                this.charts.set('financial', new Chart(financialCtx, {
                    type: 'line',
                    data: {
                        labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                        datasets: [{
                            label: 'Income',
                            data: [8000, 9500, 12000, 11500, 13000, 12500],
                            borderColor: '#00A86B',
                            backgroundColor: 'rgba(0, 168, 107, 0.08)',
                            tension: 0.4,
                            fill: true,
                            pointRadius: 4,
                            pointBackgroundColor: '#00A86B'
                        }, {
                            label: 'Expenses',
                            data: [7500, 8200, 9800, 8900, 9500, 8900],
                            borderColor: '#ef4444',
                            backgroundColor: 'rgba(239, 68, 68, 0.06)',
                            tension: 0.4,
                            fill: true,
                            pointRadius: 4,
                            pointBackgroundColor: '#ef4444'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { position: 'top' } },
                        scales: {
                            y: {
                                beginAtZero: true,
                                grid: { color: 'rgba(0,0,0,0.04)' },
                                ticks: { callback: v => `$${v.toLocaleString()}` }
                            },
                            x: { grid: { display: false } }
                        }
                    }
                }));
            }

            const donationsCtx = document.getElementById('donationsChart');
            if (donationsCtx) {
                this.charts.set('donations', new Chart(donationsCtx, {
                    type: 'doughnut',
                    data: {
                        labels: ['Events', 'Facilities', 'Administration', 'Programs'],
                        datasets: [{
                            data: [45000, 25000, 15000, 13000],
                            backgroundColor: ['#00A86B','#3b82f6','#f59e0b','#ef4444'],
                            borderWidth: 0,
                            hoverOffset: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        cutout: '72%',
                        plugins: { legend: { position: 'bottom' } }
                    }
                }));
            }
        }

        loadAnimations() {
            document.querySelectorAll('.card').forEach(card => card.classList.add('fade-in'));
            document.addEventListener('click', (e) => {
                if (e.target.matches('a[href*="#"]') && !e.target.matches('a[href="#"]')) {
                    const target = document.querySelector(e.target.hash);
                    if (target) {
                        e.preventDefault();
                        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                        setTimeout(() => window.scrollBy(0, -70), 0);
                    }
                }
            });
        }

        handleGlobalErrors() {
            window.addEventListener('unhandledrejection', () => {
                this.showToast('An unexpected error occurred. Please try again.', 'error');
            });
        }

        handleWindowResize() {
            let t;
            window.addEventListener('resize', () => {
                clearTimeout(t);
                t = setTimeout(() => {
                    this.charts.forEach(chart => chart?.resize?.());
                }, 250);
            });
        }

        createToastContainer() {
            if (!document.getElementById('toast-container')) {
                const c = document.createElement('div');
                c.id = 'toast-container';
                c.className = 'toast-container position-fixed top-0 end-0 p-3';
                c.style.zIndex = '9999';
                document.body.appendChild(c);
            }
        }

        createModal({ id, title, body, headerClass = '', buttons = [] }) {
            const modal = document.createElement('div');
            modal.className = 'modal fade';
            modal.id = id;
            modal.setAttribute('tabindex', '-1');
            const btnsHTML = buttons.map(btn =>
                `<button type="button" class="btn ${btn.class}">${btn.text}</button>`
            ).join('');
            modal.innerHTML = `
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header ${headerClass}">
                            <h5 class="modal-title">${title}</h5>
                            <button type="button" class="btn-close ${headerClass.includes('text-white') ? 'btn-close-white' : ''}" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">${body}</div>
                        <div class="modal-footer">${btnsHTML}</div>
                    </div>
                </div>`;
            buttons.forEach((btn, i) => {
                const el = modal.querySelectorAll('.modal-footer .btn')[i];
                if (typeof btn.action === 'function') {
                    el.addEventListener('click', () => {
                        btn.action();
                        bootstrap.Modal.getInstance(modal)?.hide();
                    });
                }
            });
            return modal;
        }

        validateEmail(email) {
            return /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email);
        }

        showFieldError(field, message) {
            const existing = field.parentNode.querySelector('.invalid-feedback');
            if (existing) existing.remove();
            const div = document.createElement('div');
            div.className = 'invalid-feedback';
            div.textContent = message;
            field.parentNode.insertBefore(div, field.nextSibling);
        }

        formatFileSize(bytes) {
            if (!bytes) return '0 Bytes';
            const k = 1024, sizes = ['Bytes','KB','MB','GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return `${parseFloat((bytes / Math.pow(k, i)).toFixed(2))} ${sizes[i]}`;
        }

        showToast(message, type = 'info') {
            const types = { error: 'danger', success: 'success', warning: 'warning', info: 'primary' };
            const bg = types[type] || 'primary';
            const toast = document.createElement('div');
            toast.className = `toast align-items-center text-white bg-${bg} border-0`;
            toast.setAttribute('role', 'alert');
            toast.innerHTML = `
                <div class="d-flex">
                    <div class="toast-body">${this.escapeHtml(message)}</div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast"></button>
                </div>`;
            document.getElementById('toast-container').appendChild(toast);
            const instance = new bootstrap.Toast(toast);
            instance.show();
            toast.addEventListener('hidden.bs.toast', () => toast.remove());
            return instance;
        }

        escapeHtml(str) {
            return String(str)
                .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
                .replace(/"/g,'&quot;').replace(/'/g,'&#039;');
        }

        delay(ms) { return new Promise(r => setTimeout(r, ms)); }

        readFileAsDataURL(file) {
            return new Promise((resolve, reject) => {
                const reader = new FileReader();
                reader.onload = e => resolve(e.target.result);
                reader.onerror = reject;
                reader.readAsDataURL(file);
            });
        }

        async fetchJSON(url, options = {}) {
            const response = await fetch(url, {
                headers: { 'Content-Type': 'application/json', ...options.headers },
                ...options
            });
            if (!response.ok) throw new Error(`HTTP ${response.status}`);
            return response.json();
        }
    }

    // Global helpers
    window.fillCredentials = (email, password) => {
        const e = document.querySelector('input[name="Email"]');
        const p = document.querySelector('input[name="Password"]');
        if (e && p) {
            e.value = email; p.value = password;
            [e, p].forEach(i => { i.dispatchEvent(new Event('input',{bubbles:true})); });
        }
    };

    window.togglePassword = () => {
        const input = document.querySelector('input[name="Password"]');
        const icon = document.getElementById('passwordToggleIcon');
        if (input && icon) {
            const isPass = input.type === 'password';
            input.type = isPass ? 'text' : 'password';
            icon.classList.toggle('fa-eye', !isPass);
            icon.classList.toggle('fa-eye-slash', isPass);
        }
    };

    const adminPanel = new AdminPanel();

    // =============================================
    // Session Manager
    // =============================================
    class SessionManager {
        constructor() {
            this.warningTime = 15 * 60 * 1000;
            this.sessionTimeout = 2 * 60 * 60 * 1000;
            this.warningShown = false;
            this.lastActivity = Date.now();
            this.initializeSessionTracking();
        }

        initializeSessionTracking() {
            ['mousedown','mousemove','keypress','scroll','touchstart','click'].forEach(evt => {
                document.addEventListener(evt, () => this.updateActivity(), { passive: true });
            });
            setInterval(() => this.checkSession(), 60000);
        }

        updateActivity() {
            this.lastActivity = Date.now();
            this.warningShown = false;
            const modal = document.getElementById('session-warning-modal');
            if (modal) bootstrap.Modal.getInstance(modal)?.hide();
        }

        checkSession() {
            const elapsed = Date.now() - this.lastActivity;
            if (elapsed > this.warningTime && !this.warningShown) {
                this.showSessionWarning();
                this.warningShown = true;
            }
            if (elapsed > this.sessionTimeout) this.performAutoLogout();
        }

        showSessionWarning() {
            const modal = document.createElement('div');
            modal.className = 'modal fade';
            modal.id = 'session-warning-modal';
            modal.setAttribute('tabindex', '-1');
            modal.setAttribute('data-bs-backdrop', 'static');
            modal.innerHTML = `
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header" style="background:#f59e0b;color:white;">
                            <h5 class="modal-title"><i class="fas fa-clock me-2"></i>Session Expiring Soon</h5>
                        </div>
                        <div class="modal-body text-center py-4">
                            <div class="mb-3"><i class="fas fa-hourglass-half fa-3x" style="color:#f59e0b;"></i></div>
                            <h6 class="mb-2">Your session will expire soon</h6>
                            <p class="text-muted small mb-0">You've been inactive for a while. Click "Stay Logged In" to continue.</p>
                        </div>
                        <div class="modal-footer justify-content-center">
                            <button class="btn btn-success px-4" onclick="sessionManager.extendSession()">
                                <i class="fas fa-check me-1"></i>Stay Logged In
                            </button>
                            <button class="btn btn-outline-danger px-4" onclick="sessionManager.logoutNow()">
                                <i class="fas fa-sign-out-alt me-1"></i>Logout
                            </button>
                        </div>
                    </div>
                </div>`;
            document.body.appendChild(modal);
            new bootstrap.Modal(modal).show();
        }

        extendSession() {
            this.updateActivity();
            const modal = document.getElementById('session-warning-modal');
            if (modal) {
                bootstrap.Modal.getInstance(modal)?.hide();
                setTimeout(() => modal.remove(), 400);
            }
            adminPanel.showToast('Session extended successfully', 'success');
        }

        logoutNow() {
            const form = document.createElement('form');
            form.method = 'post';
            form.action = '@Url.Action("Logout", "Account", new { area = "Admin" })';
            const token = document.querySelector('input[name="__RequestVerificationToken"]');
            if (token) {
                const t = document.createElement('input');
                t.type = 'hidden';
                t.name = '__RequestVerificationToken';
                t.value = token.value;
                form.appendChild(t);
            }
            document.body.appendChild(form);
            form.submit();
        }

        performAutoLogout() {
            adminPanel.showToast('Session expired. Logging out...', 'warning');
            setTimeout(() => this.logoutNow(), 3000);
        }
    }

    const sessionManager = new SessionManager();
    </script>
</head>
<body class="admin-body">
@{
    var ctrl   = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
    string NavClass(string c, string a = "") =>
        (ctrl == c && (string.IsNullOrEmpty(a) || action == a)) ? "nav-link active" : "nav-link";
}
@if (User.Identity?.IsAuthenticated == true)
{
    <!-- =============================================
         Sidebar
         ============================================= -->
    <aside class="sidebar" id="sidebar">

        <a class="sidebar-brand" href="@Url.Action("Index", "Dashboard", new { area = "Admin" })">
            <div class="brand-logo"><i class="fas fa-star-and-crescent"></i></div>
            <span>SAM Admin</span>
        </a>

        <nav class="sidebar-nav">
            <ul class="flex-column">

                <li class="nav-section">Main</li>
                <li class="nav-item">
                    <a class="@NavClass("Dashboard","Index")"
                       asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                        <span class="nav-icon"><i class="fas fa-home"></i></span>
                        <span>Dashboard</span>
                    </a>
                </li>

                @if (User.IsInRole("Admin") || User.IsInRole("Organization"))
                {
                    <li class="nav-section">Organization</li>
                    <li class="nav-item">
                        <a class="@NavClass("Events")"
                           asp-area="Admin" asp-controller="Events" asp-action="Index">
                            <span class="nav-icon"><i class="fas fa-calendar-alt"></i></span>
                            <span>Events</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="@NavClass("Members")"
                           asp-area="Admin" asp-controller="Members" asp-action="Index">
                            <span class="nav-icon"><i class="fas fa-id-card"></i></span>
                            <span>Members</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="@NavClass("Services")"
                           asp-area="Admin" asp-controller="Services" asp-action="Index">
                            <span class="nav-icon"><i class="fas fa-handshake"></i></span>
                            <span>Services</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="@NavClass("Leadership")"
                           asp-area="Admin" asp-controller="Leadership" asp-action="Index">
                            <span class="nav-icon"><i class="fas fa-user-tie"></i></span>
                            <span>Leadership</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="@NavClass("Testimonials")"
                           asp-area="Admin" asp-controller="Testimonials" asp-action="Index">
                            <span class="nav-icon"><i class="fas fa-star"></i></span>
                            <span>Testimonials</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="@NavClass("ContactMessages")"
                           asp-area="Admin" asp-controller="ContactMessages" asp-action="Index">
                            <span class="nav-icon"><i class="fas fa-envelope"></i></span>
                            <span>Messages</span>
                        </a>
                    </li>
                }

                @if (User.IsInRole("Admin") || User.IsInRole("Finance"))
                {
                    <li class="nav-section">Finance</li>
                    <li class="nav-item">
                        <a class="@NavClass("Finance","Index")"
                           asp-area="Admin" asp-controller="Finance" asp-action="Index">
                            <span class="nav-icon"><i class="fas fa-chart-line"></i></span>
                            <span>Overview</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="@NavClass("Finance","Donations")"
                           asp-area="Admin" asp-controller="Finance" asp-action="Donations">
                            <span class="nav-icon"><i class="fas fa-hand-holding-heart"></i></span>
                            <span>Donations</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="@NavClass("Finance","Expenses")"
                           asp-area="Admin" asp-controller="Finance" asp-action="Expenses">
                            <span class="nav-icon"><i class="fas fa-receipt"></i></span>
                            <span>Expenses</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="@NavClass("Finance","Reports")"
                           asp-area="Admin" asp-controller="Finance" asp-action="Reports">
                            <span class="nav-icon"><i class="fas fa-file-alt"></i></span>
                            <span>Reports</span>
                        </a>
                    </li>
                }

                @if (User.IsInRole("Admin"))
                {
                    <li class="nav-section">Administration</li>
                    <li class="nav-item">
                        <a class="@NavClass("Users")"
                           asp-area="Admin" asp-controller="Users" asp-action="Index">
                            <span class="nav-icon"><i class="fas fa-users-cog"></i></span>
                            <span>Users</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="@NavClass("System","Settings")"
                           asp-area="Admin" asp-controller="System" asp-action="Settings">
                            <span class="nav-icon"><i class="fas fa-sliders-h"></i></span>
                            <span>Settings</span>
                        </a>
                    </li>
                }

            </ul>
        </nav>

        <div class="sidebar-footer">
            <a href="@Url.Action("Index", "Home", new { area = "" })"
               class="sidebar-footer-link" target="_blank" rel="noopener">
                <i class="fas fa-external-link-alt" style="font-size:0.75rem;"></i>
                View Public Site
            </a>
        </div>
    </aside>

    <!-- =============================================
         Main Content
         ============================================= -->
    <div class="main-content" id="mainContent">

        <!-- Topbar -->
        <header class="topbar">
            <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
                <i class="fas fa-bars"></i>
            </button>

            <span class="topbar-breadcrumb d-none d-md-inline">
                SAM &rsaquo; <span class="page-name">@(ViewData["Title"] ?? "Dashboard")</span>
            </span>

            <div class="topbar-right">
                <a href="@Url.Action("Index", "ContactMessages", new { area = "Admin" })"
                   class="topbar-btn" data-bs-toggle="tooltip" title="Messages">
                    <i class="fas fa-envelope"></i>
                </a>

                <div class="topbar-divider"></div>

                <div class="dropdown">
                    <button class="topbar-user-btn dropdown-toggle" data-bs-toggle="dropdown">
                        <div class="user-avatar">
                            <i class="fas fa-user"></i>
                        </div>
                        <span class="user-name">@User.Identity?.Name</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end" style="min-width:200px;">
                        <li>
                            <span class="dropdown-item-text text-muted">
                                <i class="fas fa-shield-alt me-1"></i>
                                @string.Join(", ", ((System.Security.Claims.ClaimsPrincipal)User)
                                    .FindAll(System.Security.Claims.ClaimTypes.Role)
                                    .Select(c => c.Value))
                            </span>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <a class="dropdown-item" href="@Url.Action("Index", "Home", new { area = "" })" target="_blank">
                                <i class="fas fa-globe"></i> View Website
                            </a>
                        </li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li>
                                <a class="dropdown-item" asp-area="Admin" asp-controller="System" asp-action="Settings">
                                    <i class="fas fa-cog"></i> Settings
                                </a>
                            </li>
                        }
                        <li><hr class="dropdown-divider"></li>
                        <li>
                            <form asp-area="Admin" asp-controller="Account" asp-action="Logout" method="post">
                                <button type="submit" class="dropdown-item text-danger">
                                    <i class="fas fa-sign-out-alt"></i> Logout
                                </button>
                            </form>
                        </li>
                    </ul>
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <main class="page-content">
            @RenderBody()
        </main>
    </div>

    <!-- Mobile overlay -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
}
else
{
    @RenderBody()
}

<!-- Scripts -->
<script src="@Url.Content("~/js/fix-unload-warnings.js")"></script>
<script src="@Url.Content("~/lib/jquery/dist/jquery.min.js")"></script>
<script src="@Url.Content("~/lib/bootstrap/dist/js/bootstrap.bundle.min.js")"></script>
<script src="https://cdn.datatables.net/2.0.3/js/dataTables.min.js"></script>
<script src="https://cdn.datatables.net/2.0.3/js/dataTables.bootstrap5.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    // Sidebar toggle
    document.addEventListener('DOMContentLoaded', function () {
        const sidebar = document.getElementById('sidebar');
        const toggle = document.getElementById('sidebarToggle');
        const overlay = document.getElementById('sidebarOverlay');

        if (toggle && sidebar) {
            toggle.addEventListener('click', function () {
                sidebar.classList.toggle('open');
                overlay?.classList.toggle('show');
            });
        }

        if (overlay) {
            overlay.addEventListener('click', function () {
                sidebar?.classList.remove('open');
                overlay.classList.remove('show');
            });
        }
    });
</script>

@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
