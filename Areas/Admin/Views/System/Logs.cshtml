@model IEnumerable<SenegaleseAssociation.Areas.Admin.Models.SystemLogViewModel>
@{
    ViewData["Title"] = "System Logs";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="page-header">
    <div class="page-header-left">
        <h1>System Logs</h1>
        <p class="subtitle">Recent application activity and error log</p>
    </div>
    <a asp-action="Settings" class="btn btn-secondary">
        <i class="fas fa-arrow-left"></i> Back to Settings
    </a>
</div>

<div class="card">
    <div class="card-header">
        <div class="card-title">
            <div class="card-header-icon" style="background:rgba(59,130,246,0.1);color:#3b82f6;">
                <i class="fas fa-list-alt"></i>
            </div>
            Recent System Activity
        </div>
        <span class="badge bg-secondary">@Model.Count() entries</span>
    </div>
    <div class="table-responsive">
        <table class="table data-table" id="logsTable">
            <thead>
                <tr>
                    <th>Date / Time</th>
                    <th>Level</th>
                    <th>Message</th>
                    <th>User</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr>
                        <td style="white-space:nowrap;">
                            <i class="fas fa-clock me-1" style="color:var(--text-muted);font-size:.75rem;"></i>
                            @log.Date.ToString("MM/dd/yyyy HH:mm:ss")
                        </td>
                        <td>
                            @switch (log.Level)
                            {
                                case "INFO":
                                    <span class="badge bg-info">@log.Level</span>
                                    break;
                                case "WARN":
                                    <span class="badge bg-warning">@log.Level</span>
                                    break;
                                case "ERROR":
                                    <span class="badge bg-danger">@log.Level</span>
                                    break;
                                default:
                                    <span class="badge bg-secondary">@log.Level</span>
                                    break;
                            }
                        </td>
                        <td>@log.Message</td>
                        <td>
                            <span style="font-size:.8rem;color:var(--text-muted);">
                                <i class="fas fa-user me-1"></i>@log.User
                            </span>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    // DataTable initialized by AdminPanel class via .data-table selector
</script>
}
