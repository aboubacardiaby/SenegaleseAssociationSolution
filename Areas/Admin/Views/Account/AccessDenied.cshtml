@{
    ViewData["Title"] = "Access Denied";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="min-vh-100 d-flex align-items-center justify-content-center">
    <div class="text-center">
        <div class="mb-4">
            <i class="fas fa-lock text-danger" style="font-size: 4rem;"></i>
        </div>
        <h1 class="display-4 text-danger">Access Denied</h1>
        <p class="lead">You don't have permission to access this resource.</p>
        <div class="mt-4">
            <a asp-area="Admin" asp-controller="Dashboard" asp-action="Index" class="btn btn-primary me-2">Dashboard</a>
            <a asp-area="" asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Back to Website</a>
        </div>
    </div>
</div>