@model SenegaleseAssociation.Areas.Admin.Models.FinanceOverviewViewModel
@{
    ViewData["Title"] = "Finance Overview";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">
        <i class="fas fa-dollar-sign text-success"></i> Finance Overview
    </h1>
</div>

<!-- Financial Stats Cards -->
<div class="row mb-4">
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Total Income</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">$@Model.TotalIncome.ToString("N0")</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-arrow-up fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-danger shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Total Expenses</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">$@Model.TotalExpenses.ToString("N0")</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-arrow-down fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Net Income</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">$@Model.NetIncome.ToString("N0")</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-chart-line fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-warning shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">Pending Donations</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@Model.PendingDonations</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-clock fa-2x text-gray-300"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Monthly Overview -->
<div class="row mb-4">
    <div class="col-lg-8">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Monthly Financial Overview</h6>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="text-center">
                            <div class="h4 text-success">$@Model.MonthlyIncome.ToString("N0")</div>
                            <div class="text-muted">Monthly Income</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-center">
                            <div class="h4 text-danger">$@Model.MonthlyExpenses.ToString("N0")</div>
                            <div class="text-muted">Monthly Expenses</div>
                        </div>
                    </div>
                </div>
                <hr>
                <div class="text-center">
                    <div class="h5 @(Model.MonthlyNet >= 0 ? "text-success" : "text-danger")">
                        $@Model.MonthlyNet.ToString("N0")
                    </div>
                    <div class="text-muted">Monthly Net @(Model.MonthlyNet >= 0 ? "Income" : "Loss")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Quick Actions</h6>
            </div>
            <div class="card-body">
                <div class="d-grid gap-2">
                    <a asp-action="Donations" class="btn btn-outline-primary">
                        <i class="fas fa-heart"></i> Manage Donations
                    </a>
                    <a asp-action="Expenses" class="btn btn-outline-secondary">
                        <i class="fas fa-receipt"></i> Track Expenses
                    </a>
                    <a asp-action="Reports" class="btn btn-outline-info">
                        <i class="fas fa-chart-bar"></i> View Reports
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Recent Transactions -->
<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Recent Transactions</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Description</th>
                        <th>Category</th>
                        <th>Type</th>
                        <th>Amount</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var transaction in Model.RecentTransactions)
                    {
                        <tr>
                            <td>@transaction.Date.ToString("MM/dd/yyyy")</td>
                            <td>@transaction.Description</td>
                            <td><span class="badge bg-secondary">@transaction.Category</span></td>
                            <td>
                                <span class="badge @(transaction.Type == "Income" ? "bg-success" : "bg-danger")">
                                    @transaction.Type
                                </span>
                            </td>
                            <td class="@(transaction.Amount >= 0 ? "text-success" : "text-danger") fw-bold">
                                $@Math.Abs(transaction.Amount).ToString("N2")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>