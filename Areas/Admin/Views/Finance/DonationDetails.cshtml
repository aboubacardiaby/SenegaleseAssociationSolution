@model SenegaleseAssociation.Models.Donation
@{
    ViewData["Title"] = "Donation Details";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">
        <i class="fas fa-heart text-success"></i> Donation Details
    </h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <a asp-action="Donations" class="btn btn-sm btn-outline-secondary">
            <i class="fas fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-info-circle"></i> Donation Information
                </h6>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="text-muted small">Transaction ID</label>
                        <p class="font-weight-bold">@Model.TransactionId</p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small">Status</label>
                        <p>
                            @if (Model.Status == "Completed")
                            {
                                <span class="badge bg-success">
                                    <i class="fas fa-check"></i> Completed
                                </span>
                            }
                            else if (Model.Status == "Pending")
                            {
                                <span class="badge bg-warning">
                                    <i class="fas fa-clock"></i> Pending
                                </span>
                            }
                            else if (Model.Status == "Failed")
                            {
                                <span class="badge bg-danger">
                                    <i class="fas fa-times"></i> Failed
                                </span>
                            }
                            else if (Model.Status == "Cancelled")
                            {
                                <span class="badge bg-secondary">
                                    <i class="fas fa-ban"></i> Cancelled
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@Model.Status</span>
                            }
                        </p>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="text-muted small">Amount</label>
                        <p class="font-weight-bold text-success h4">$@Model.Amount.ToString("N2")</p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small">Frequency</label>
                        <p><span class="badge bg-info">@Model.Frequency</span></p>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="text-muted small">Payment Method</label>
                        <p>
                            @if (Model.PaymentMethod.ToLower() == "paypal")
                            {
                                <i class="fab fa-paypal text-primary"></i>
                            }
                            else if (Model.PaymentMethod.ToLower() == "stripe" || Model.PaymentMethod.ToLower() == "ach")
                            {
                                <i class="fab fa-stripe text-info"></i>
                            }
                            @Model.PaymentMethod
                        </p>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small">Created Date</label>
                        <p>@Model.CreatedAt.ToString("MMMM dd, yyyy 'at' h:mm tt")</p>
                    </div>
                </div>

                @if (Model.ProcessedDate.HasValue)
                {
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="text-muted small">Processed Date</label>
                            <p>@Model.ProcessedDate.Value.ToString("MMMM dd, yyyy 'at' h:mm tt")</p>
                        </div>
                        @if (Model.ProcessedBy != null)
                        {
                            <div class="col-md-6">
                                <label class="text-muted small">Processed By</label>
                                <p>@Model.ProcessedBy.UserName</p>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-user"></i> Donor Information
                </h6>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-12">
                        <label class="text-muted small">Donor Name</label>
                        <p class="font-weight-bold">
                            @if (Model.IsAnonymous)
                            {
                                <span class="text-muted">
                                    <i class="fas fa-user-secret"></i> Anonymous
                                </span>
                            }
                            else
                            {
                                @Model.DonorName
                            }
                        </p>
                    </div>
                </div>

                @if (!Model.IsAnonymous)
                {
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="text-muted small">Email</label>
                            <p>
                                @if (!string.IsNullOrEmpty(Model.DonorEmail))
                                {
                                    <a href="mailto:@Model.DonorEmail">@Model.DonorEmail</a>
                                }
                                else
                                {
                                    <span class="text-muted">Not provided</span>
                                }
                            </p>
                        </div>
                        <div class="col-md-6">
                            <label class="text-muted small">Phone</label>
                            <p>
                                @if (!string.IsNullOrEmpty(Model.DonorPhone))
                                {
                                    <a href="tel:@Model.DonorPhone">@Model.DonorPhone</a>
                                }
                                else
                                {
                                    <span class="text-muted">Not provided</span>
                                }
                            </p>
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(Model.Message))
                    {
                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label class="text-muted small">Message</label>
                                <p class="bg-light p-3 rounded">@Model.Message</p>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Notes))
        {
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">
                        <i class="fas fa-sticky-note"></i> Internal Notes
                    </h6>
                </div>
                <div class="card-body">
                    <p>@Model.Notes</p>
                </div>
            </div>
        }
    </div>

    <div class="col-lg-4">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-cog"></i> Actions
                </h6>
            </div>
            <div class="card-body">
                @if (Model.Status == "Pending")
                {
                    <form asp-action="ApproveDonation" method="post" class="mb-2">
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-success btn-block w-100 mb-2">
                            <i class="fas fa-check"></i> Approve Donation
                        </button>
                    </form>
                }

                <a asp-action="EditDonation" asp-route-id="@Model.Id" class="btn btn-primary btn-block w-100 mb-2">
                    <i class="fas fa-edit"></i> Edit Donation
                </a>

                <form asp-action="DeleteDonation" method="post" class="delete-form">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <button type="submit" class="btn btn-danger btn-block w-100"
                            onclick="return confirm('Are you sure you want to delete this donation?');">
                        <i class="fas fa-trash"></i> Delete Donation
                    </button>
                </form>
            </div>
        </div>

        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">
                    <i class="fas fa-clock"></i> Timeline
                </h6>
            </div>
            <div class="card-body">
                <div class="timeline">
                    <div class="timeline-item">
                        <div class="timeline-marker bg-primary"></div>
                        <div class="timeline-content">
                            <p class="mb-0 small text-muted">Created</p>
                            <p class="mb-0 small">@Model.CreatedAt.ToString("MMM dd, yyyy h:mm tt")</p>
                        </div>
                    </div>

                    @if (Model.UpdatedAt != Model.CreatedAt)
                    {
                        <div class="timeline-item">
                            <div class="timeline-marker bg-info"></div>
                            <div class="timeline-content">
                                <p class="mb-0 small text-muted">Last Updated</p>
                                <p class="mb-0 small">@Model.UpdatedAt.ToString("MMM dd, yyyy h:mm tt")</p>
                            </div>
                        </div>
                    }

                    @if (Model.ProcessedDate.HasValue)
                    {
                        <div class="timeline-item">
                            <div class="timeline-marker bg-success"></div>
                            <div class="timeline-content">
                                <p class="mb-0 small text-muted">Processed</p>
                                <p class="mb-0 small">@Model.ProcessedDate.Value.ToString("MMM dd, yyyy h:mm tt")</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .timeline {
            position: relative;
            padding-left: 30px;
        }

        .timeline-item {
            position: relative;
            padding-bottom: 20px;
        }

        .timeline-item:before {
            content: '';
            position: absolute;
            left: -22px;
            top: 5px;
            bottom: -15px;
            width: 2px;
            background: #e9ecef;
        }

        .timeline-item:last-child:before {
            display: none;
        }

        .timeline-marker {
            position: absolute;
            left: -27px;
            top: 3px;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            border: 2px solid #fff;
            box-shadow: 0 0 0 2px currentColor;
        }

        .timeline-content {
            padding-left: 10px;
        }
    </style>
}
