@model List<SenegaleseAssociation.Areas.Admin.Models.DonationViewModel>
@{
    ViewData["Title"] = "Donations Management";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    var statusFilter = ViewBag.StatusFilter as string ?? "All";
    var startDate = ViewBag.StartDate as DateTime?;
    var endDate = ViewBag.EndDate as DateTime?;
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">
        <i class="fas fa-heart text-success"></i> Donations Management
    </h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <div class="btn-group me-2">
            <a asp-action="ExportDonations" asp-route-status="@statusFilter"
               asp-route-startDate="@startDate" asp-route-endDate="@endDate"
               class="btn btn-sm btn-success">
                <i class="fas fa-download"></i> Export CSV
            </a>
            <button type="button" class="btn btn-sm btn-outline-secondary" onclick="window.print()">
                <i class="fas fa-print"></i> Print
            </button>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-filter"></i> Filters
        </h6>
    </div>
    <div class="card-body">
        <form asp-action="Donations" method="get" class="row g-3">
            <div class="col-md-3">
                <label for="status" class="form-label">Status</label>
                <select name="status" id="status" class="form-select">
                    <option value="All" selected="@(statusFilter == "All")">All</option>
                    <option value="Pending" selected="@(statusFilter == "Pending")">Pending</option>
                    <option value="Completed" selected="@(statusFilter == "Completed")">Completed</option>
                    <option value="Failed" selected="@(statusFilter == "Failed")">Failed</option>
                    <option value="Cancelled" selected="@(statusFilter == "Cancelled")">Cancelled</option>
                </select>
            </div>
            <div class="col-md-3">
                <label for="startDate" class="form-label">Start Date</label>
                <input type="date" name="startDate" id="startDate" class="form-control"
                       value="@(startDate?.ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-md-3">
                <label for="endDate" class="form-label">End Date</label>
                <input type="date" name="endDate" id="endDate" class="form-control"
                       value="@(endDate?.ToString("yyyy-MM-dd"))" />
            </div>
            <div class="col-md-3">
                <label class="form-label">&nbsp;</label>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-search"></i> Filter
                    </button>
                    <a asp-action="Donations" class="btn btn-secondary">
                        <i class="fas fa-redo"></i> Reset
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Quick Stats -->
<div class="row mb-4">
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="card border-left-success stats-card shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-white text-uppercase mb-1">Total Raised</div>
                        <div class="h5 mb-0 font-weight-bold text-white">$@Model.Sum(d => d.Amount).ToString("N0")</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-dollar-sign fa-2x text-white opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="card border-left-primary stats-card shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-white text-uppercase mb-1">Total Donors</div>
                        <div class="h5 mb-0 font-weight-bold text-white">@Model.Count</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-users fa-2x text-white opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="card border-left-warning stats-card shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-white text-uppercase mb-1">Pending</div>
                        <div class="h5 mb-0 font-weight-bold text-white">@Model.Count(d => d.Status == "Pending")</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-clock fa-2x text-white opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-lg-3 col-md-6 mb-3">
        <div class="card border-left-info stats-card shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-white text-uppercase mb-1">Average</div>
                        <div class="h5 mb-0 font-weight-bold text-white">$@(Model.Any() ? Model.Average(d => d.Amount).ToString("N0") : "0")</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-chart-bar fa-2x text-white opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Donations Table -->
<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">
            <i class="fas fa-list"></i> All Donations
            @if (Model != null && Model.Any())
            {
                <span class="badge bg-primary">@Model.Count</span>
            }
        </h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered data-table" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>Donor Name</th>
                        <th>Email</th>
                        <th>Amount</th>
                        <th>Purpose</th>
                        <th>Date</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null)
                    {
                        @foreach (var donation in Model)
                        {
                        <tr class="fade-in searchable-item">
                            <td class="fw-bold">@donation.DonorName</td>
                            <td>
                                @if (!string.IsNullOrEmpty(donation.Email))
                                {
                                    <a href="mailto:@donation.Email" class="text-decoration-none">
                                        @donation.Email
                                    </a>
                                }
                                else
                                {
                                    <span class="text-muted">Not provided</span>
                                }
                            </td>
                            <td class="fw-bold text-success">$@donation.Amount.ToString("N2")</td>
                            <td>
                                <span class="badge bg-secondary">@donation.Purpose</span>
                            </td>
                            <td>@donation.Date.ToString("MMM dd, yyyy")</td>
                            <td>
                                @if (donation.Status == "Completed")
                                {
                                    <span class="badge bg-success">
                                        <i class="fas fa-check"></i> Completed
                                    </span>
                                }
                                else if (donation.Status == "Pending")
                                {
                                    <span class="badge bg-warning">
                                        <i class="fas fa-clock"></i> Pending
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@donation.Status</span>
                                }
                            </td>
                            <td>
                                <div class="action-buttons d-flex gap-1">
                                    <a asp-action="DonationDetails" asp-route-id="@donation.Id"
                                       class="btn btn-info btn-sm"
                                       data-bs-toggle="tooltip" title="View details">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                    <a asp-action="EditDonation" asp-route-id="@donation.Id"
                                       class="btn btn-primary btn-sm"
                                       data-bs-toggle="tooltip" title="Edit donation">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    @if (donation.Status == "Pending")
                                    {
                                        <form asp-action="ApproveDonation" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@donation.Id" />
                                            <button type="submit" class="btn btn-success btn-sm"
                                                    data-bs-toggle="tooltip" title="Approve donation">
                                                <i class="fas fa-check"></i>
                                            </button>
                                        </form>
                                    }
                                    <form asp-action="DeleteDonation" method="post" class="d-inline">
                                        <input type="hidden" name="id" value="@donation.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm"
                                                onclick="return confirm('Are you sure you want to delete this donation from @donation.DonorName?');"
                                                data-bs-toggle="tooltip" title="Delete donation">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Initialize DataTable with custom options
        $(document).ready(function() {
            // Check if DataTable already exists and destroy it
            if ($.fn.DataTable.isDataTable('.data-table')) {
                $('.data-table').DataTable().destroy();
            }

            // Initialize DataTable
            $('.data-table').DataTable({
                order: [[4, 'desc']], // Sort by date descending
                columnDefs: [
                    { orderable: false, targets: [6] }, // Disable sorting for Actions column
                ],
                responsive: true,
                pageLength: 25
            });
        });
    </script>
}